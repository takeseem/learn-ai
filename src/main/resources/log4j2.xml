<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="info" monitorInterval="5">
	<Properties>
		<Property name="logPath">${env:LOG_ROOT:-logs}/${env:mykey:-learn-ai}</Property>
		<Property name="LOG_LEVEL_PATTERN">%5p</Property>
		<Property name="LOG_DATEFORMAT_PATTERN">yyyy-MM-dd HH:mm:ss.SSS</Property>
		<Property name="DEFAULT_LOG_PATTERN">%d{${LOG_DATEFORMAT_PATTERN}} ${LOG_LEVEL_PATTERN} [%pid][%t] [%X] %m (%F:%L) %c.%M%n</Property>
		<Property name="FILE_LOG_PATTERN">${sys:DEFAULT_LOG_PATTERN}</Property>
		
<!--		<Property name="CONSOLE_LOG_PATTERN">${sys:DEFAULT_LOG_PATTERN}</Property>-->
<!--		<Property name="CONSOLE_LOG_PATTERN">%d{${LOG_DATEFORMAT_PATTERN}} [%pid][%t][%X] %highlight{${LOG_LEVEL_PATTERN}} %m (%F:%L) %c.%M%n</Property>-->
		<Property name="CONSOLE_LOG_PATTERN">%d{${LOG_DATEFORMAT_PATTERN}} %highlight{${LOG_LEVEL_PATTERN}} [%t] %m (%F:%L) %c.%M%n</Property>
		
	</Properties>
	
	<Appenders>
		<Console name="Console" follow="true">
			<PatternLayout pattern="${sys:CONSOLE_LOG_PATTERN}" />
		</Console>
		<RollingRandomAccessFile name="allFile" fileName="${logPath}/all.log" filePattern="${logPath}/all.log.%d{yyyy-MM-dd}" immediateFlush="true">
			<PatternLayout pattern="${sys:FILE_LOG_PATTERN}" />
			<Policies>
				<TimeBasedTriggeringPolicy />
			</Policies>
			<DefaultRolloverStrategy>
				<Delete basePath="${logPath}">
					<IfFileName regex="all\.log\.[\d-]{10,10}$" />
					<IfLastModified age="3d" />
				</Delete>
			</DefaultRolloverStrategy>
		</RollingRandomAccessFile>
	</Appenders>

	<Loggers>
		<Logger name="com.takeseem" level="debug" />
		<Logger name="com.takeseem.framework.vertx.web.handler.ResourceHandler" level="debug" />
<!--		<Logger name="org.springframework" level="all"/>-->
		
<!--		<Logger name="org.apache.catalina.startup.DigesterFactory" level="error" />-->
<!--		<Logger name="org.apache.catalina.util.LifecycleBase" level="error" />-->
<!--		<Logger name="org.apache.coyote.http11.Http11NioProtocol" level="warn" />-->
<!--		<Logger name="org.apache.sshd.common.util.SecurityUtils" level="warn"/>-->
<!--		<Logger name="org.apache.tomcat.util.net.NioSelectorPool" level="warn" />-->
<!--		<Logger name="org.eclipse.jetty.util.component.AbstractLifeCycle" level="error" />-->
<!--		<Logger name="org.hibernate.validator.internal.util.Version" level="warn" />-->
<!--		<Logger name="org.springframework.boot.actuate.endpoint.jmx" level="warn"/>-->
		
		<AsyncRoot level="info" includeLocation="true">
			<AppenderRef ref="Console" />
			<AppenderRef ref="allFile" />
		</AsyncRoot>
	</Loggers>
</Configuration>